# ============================================
# Next.js frontend (already used by src/lib/supabase.ts)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Backend pipeline (used by backend/config.py)
# ============================================
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (for LLM event extraction)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o

# Public submission confirmation emails
SUBMISSIONS_SMTP_HOST=smtp.gmail.com
SUBMISSIONS_SMTP_PORT=465
SUBMISSIONS_SMTP_SECURE=true
SUBMISSIONS_SMTP_USER=dudziktomasz@googlemail.com
SUBMISSIONS_SMTP_PASS=your-gmail-app-password
SUBMISSIONS_FROM_EMAIL=dudziktomasz@googlemail.com
SUBMISSIONS_REPLY_TO=dudziktomasz@googlemail.com
